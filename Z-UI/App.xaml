<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ZUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZapretGUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Шрифты -->
            <FontFamily x:Key="AppFontFamily">Segoe UI Variable Text</FontFamily>
            <FontFamily x:Key="AppFontDisplay">Segoe UI Variable Display</FontFamily>
            <FontFamily x:Key="AppFontMono">Cascadia Mono, Consolas</FontFamily>

            <!-- Размеры -->
            <x:Double x:Key="FontSizeSmall">11</x:Double>
            <x:Double x:Key="FontSizeBody">14</x:Double>
            <x:Double x:Key="FontSizeSubtitle">18</x:Double>
            <x:Double x:Key="FontSizeTitle">28</x:Double>

            <!-- Переопределение базового стиля TextBlock -->
            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>