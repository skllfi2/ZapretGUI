<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ZUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Z-UI">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Resources>
        <!-- Стиль элемента навигации: иконка + подпись снизу, как в MS Store -->
        <Style x:Key="StoreNavItemStyle" TargetType="NavigationViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="64"/>
            <Setter Property="ToolTipService.ToolTip" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="NavigationViewItem">
                        <Grid x:Name="LayoutRoot"
                              Background="Transparent"
                              MinHeight="{TemplateBinding MinHeight}"
                              Width="{TemplateBinding Width}"
                              ToolTipService.ToolTip="{x:Null}">

                            <!-- Фон -->
                            <Rectangle x:Name="BackgroundRect"
                                       Fill="{ThemeResource NavigationViewItemBackground}"
                                       RadiusX="4" RadiusY="4"
                                       Margin="4,2"/>

                            <!-- Иконка + текст вертикально -->
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="2"
                                        Margin="0,8">
                                <ContentPresenter x:Name="Icon"
                                                  Content="{TemplateBinding Icon}"
                                                  HorizontalAlignment="Center"
                                                  Width="20" Height="20"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                <TextBlock x:Name="ContentText"
                                           Text="{TemplateBinding Content}"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{ThemeResource NavigationViewItemForeground}"/>
                            </StackPanel>

                            <!-- Индикатор выбора — строго на левом краю, по центру высоты -->
                            <Rectangle x:Name="SelectionIndicator"
                                       Fill="{ThemeResource NavigationViewSelectionIndicatorForeground}"
                                       Width="3" Height="20"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="0"
                                       Opacity="0"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundRect.Fill" Value="{ThemeResource NavigationViewItemBackground}"/>
                                            <Setter Target="SelectionIndicator.Opacity" Value="0"/>
                                            <Setter Target="ContentText.Visibility" Value="Visible"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundRect.Fill" Value="{ThemeResource NavigationViewItemBackgroundPointerOver}"/>
                                            <Setter Target="SelectionIndicator.Opacity" Value="0"/>
                                            <Setter Target="ContentText.Visibility" Value="Visible"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundRect.Fill" Value="{ThemeResource NavigationViewItemBackgroundPressed}"/>
                                            <Setter Target="SelectionIndicator.Opacity" Value="0"/>
                                            <Setter Target="ContentText.Visibility" Value="Visible"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundRect.Fill" Value="{ThemeResource NavigationViewItemBackgroundSelected}"/>
                                            <Setter Target="SelectionIndicator.Opacity" Value="1"/>
                                            <Setter Target="ContentText.Visibility" Value="Collapsed"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOverSelected">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundRect.Fill" Value="{ThemeResource NavigationViewItemBackgroundSelectedPointerOver}"/>
                                            <Setter Target="SelectionIndicator.Opacity" Value="1"/>
                                            <Setter Target="ContentText.Visibility" Value="Collapsed"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PressedSelected">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundRect.Fill" Value="{ThemeResource NavigationViewItemBackgroundSelectedPressed}"/>
                                            <Setter Target="SelectionIndicator.Opacity" Value="1"/>
                                            <Setter Target="ContentText.Visibility" Value="Collapsed"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Opacity" Value="0.4"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="80,0,0,0"
                        Spacing="10">
                <Image Source="Assets/Z-UI-16x16.png" Width="16" Height="16"
                       VerticalAlignment="Center"/>
                <TextBlock x:Uid="ZUI" Text="Z-UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavigationViewControl"
                        Grid.Row="0" Grid.RowSpan="2"
                        PaneDisplayMode="LeftCompact"
                        CompactPaneLength="72"
                        IsTabStop="True"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        IsBackButtonVisible="Visible"
                        IsBackEnabled="False"
                        IsTitleBarAutoPaddingEnabled="False"
                        BackRequested="NavigationView_BackRequested"
                        SelectionChanged="NavigationView_SelectionChanged"
                        Loaded="NavigationView_Loaded">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="Glavnaya" Content="Главная" Icon="Home"
                                    Tag="dashboard"
                                    Style="{StaticResource StoreNavItemStyle}"
                                    ToolTipService.ToolTip="{x:Null}"/>
                <NavigationViewItem x:Uid="Strategii" Content="Стратегии" Icon="Library"
                                    Tag="strategies"
                                    Style="{StaticResource StoreNavItemStyle}"
                                    ToolTipService.ToolTip="{x:Null}"/>
                <NavigationViewItem x:Uid="UpdatesNavItem" x:Name="UpdatesNavItem"
                                    Content="Сервисы" Tag="updates"
                                    Style="{StaticResource StoreNavItemStyle}"
                                    ToolTipService.ToolTip="{x:Null}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71D;"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="UpdatesBadge"
                                   Visibility="Collapsed"
                                   Style="{ThemeResource AttentionIconInfoBadgeStyle}"/>
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Uid="SettingsNavItem" x:Name="SettingsNavItem"
                                    Content="Параметры"
                                    Tag="settings"
                                    Style="{StaticResource StoreNavItemStyle}"
                                    ToolTipService.ToolTip="{x:Null}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="16"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"/>

                    <TextBlock x:Uid="PageHeader" x:Name="PageHeader"
                               Grid.Row="1"
                               Text="Главная"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Margin="24,4,0,8"
                               VerticalAlignment="Center"/>

                    <Frame x:Name="ContentFrame" Grid.Row="2" IsTabStop="True"/>
                </Grid>
            </NavigationView.Content>

        </NavigationView>
    </Grid>
</Window>
