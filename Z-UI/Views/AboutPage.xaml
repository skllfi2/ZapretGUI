<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ZUI.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="24,16,24,32" MaxWidth="680">

            <!-- Шапка приложения -->
            <Border CornerRadius="12" Padding="32"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <Image Source="/Assets/Z-UI.ico"
                           Width="72" Height="72"
                           HorizontalAlignment="Center"/>
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock x:Uid="ZuiAbout" Text="Z-UI"
                                   Style="{ThemeResource TitleLargeTextBlockStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Uid="AppVersionText" x:Name="AppVersionText"
                                   Text="Версия 1.0.0"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Uid="GraficheskiyInterfeysDlyaUpravleniyaInstrumentomOb" Text="Графический интерфейс для управления инструментом обхода DPI zapret-discord-youtube"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Opacity="0.7"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <HyperlinkButton x:Uid="Github" Content="GitHub"
                                         NavigateUri="https://github.com/Flowseal/zapret-discord-youtube"/>
                        <TextBlock x:Uid="Control" Text="·" VerticalAlignment="Center" Opacity="0.3"/>
                        <HyperlinkButton x:Uid="SoobschitObOshibke" Content="Сообщить об ошибке"
                                         NavigateUri="https://github.com/Flowseal/zapret-discord-youtube/issues"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- zapret -->
            <TextBlock x:Uid="OZapret" Text="О ZAPRET"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.45" CharacterSpacing="80"
                       Margin="2,4,0,0"/>

            <Border CornerRadius="12" Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>

                    <Grid Padding="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Uid="ZapretDiscordYoutube" Text="zapret-discord-youtube"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="ZapretVersionText" x:Name="ZapretVersionText"
                                       Text="Версия не установлена"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.6"/>
                        </StackPanel>
                        <HyperlinkButton x:Uid="OtkrytGithub" Grid.Column="1"
                                         Content="Открыть GitHub →"
                                         VerticalAlignment="Center"
                                         NavigateUri="https://github.com/Flowseal/zapret-discord-youtube"/>
                    </Grid>

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                               Margin="20,0"/>

                    <StackPanel Padding="20,16" Spacing="6">
                        <TextBlock x:Uid="LitsenziyaZapretMit" Text="Лицензия zapret: MIT"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"/>
                        <TextBlock x:Uid="AvtorFlowsealIKontribyutory" Text="Автор: Flowseal и контрибьюторы"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.7"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Компоненты -->
            <TextBlock x:Uid="Komponenty" Text="КОМПОНЕНТЫ"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.45" CharacterSpacing="80"
                       Margin="2,4,0,0"/>

            <Border CornerRadius="12" Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>

                    <Grid Padding="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Uid="Winui3WindowsAppSdk" Text="WinUI 3 / Windows App SDK"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="UiFreymvork" Text="UI фреймворк"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock x:Uid="Microsoft" Grid.Column="1" Text="Microsoft"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="20,0"/>

                    <Grid Padding="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Uid="Net10" Text=".NET 10"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="Platforma" Text="Платформа"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock x:Uid="Microsoft1" Grid.Column="1" Text="Microsoft"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="20,0"/>

                    <Grid Padding="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Uid="Windivert" Text="WinDivert"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="PerekhvatSetevykhPaketov" Text="Перехват сетевых пакетов"
                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock x:Uid="Basil00" Grid.Column="1" Text="basil00"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.5" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Системная информация -->
            <TextBlock x:Uid="Sistema" Text="СИСТЕМА"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.45" CharacterSpacing="80"
                       Margin="2,4,0,0"/>

            <Border CornerRadius="12" Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>

                    <Grid Padding="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="VersiyaOs" Text="Версия ОС" Style="{ThemeResource BodyTextBlockStyle}"/>
                        <TextBlock x:Uid="OsVersionText" x:Name="OsVersionText" Grid.Column="1"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6" VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="20,0"/>

                    <Grid Padding="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="DirektoriyaPrilozheniya" Text="Директория приложения" Style="{ThemeResource BodyTextBlockStyle}"/>
                        <HyperlinkButton x:Uid="AppDirButton" x:Name="AppDirButton" Grid.Column="1"
                                         Content="Открыть →"
                                         Click="AppDirButton_Click"
                                         VerticalAlignment="Center"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="20,0"/>

                    <Grid Padding="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="DirektoriyaNastroek" Text="Директория настроек" Style="{ThemeResource BodyTextBlockStyle}"/>
                        <HyperlinkButton x:Uid="Otkryt" Grid.Column="1"
                                         Content="Открыть →"
                                         Click="SettingsDirButton_Click"
                                         VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
