<Page
    x:Class="ZUI.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="32,24">


            <TextBlock x:Uid="ProverkaKomponentovSistemyIKonfiguratsiiZapret" Text="Проверка компонентов системы и конфигурации zapret"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.6"
                       Margin="0,-8,0,0"/>

            <!-- Список проверок -->
            <Border CornerRadius="12" Padding="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel x:Name="ChecksList" Spacing="2"/>
            </Border>

            <!-- Итог -->
            <InfoBar x:Name="SummaryBar"
                     IsOpen="False"
                     IsClosable="False"
                     Title=""/>

        </StackPanel>
    </ScrollViewer>
</Page>
