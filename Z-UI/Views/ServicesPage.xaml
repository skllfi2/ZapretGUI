<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ZUI.Views.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>



        <Pivot Grid.Row="1" x:Name="MainPivot">

            <!-- ══ Обновления ══  index=0 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE895;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="Obnovleniya" Text="Обновления" VerticalAlignment="Center"/>
                        <Border x:Name="UpdatesTabBadge"
                                Visibility="Collapsed"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Background="{ThemeResource SystemFillColorAttentionBrush}"
                                VerticalAlignment="Top"
                                Margin="0,2,0,0"/>
                    </StackPanel>
                </PivotItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Padding="0,8,0,24">

                        <!-- Версия zapret -->
                        <Border CornerRadius="12" Padding="24"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="VersiyaZapretDiscordYoutube" Text="Версия zapret-discord-youtube"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="VersionStatusText" x:Name="VersionStatusText" Text="Проверяется..."
                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                </StackPanel>
                                <Button x:Uid="CheckVersionButton" x:Name="CheckVersionButton" Grid.Column="1"
                                        Content="Проверить"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        VerticalAlignment="Center"
                                        Click="CheckVersion_Click"/>
                            </Grid>
                        </Border>

                        <!-- Прогресс обновления -->
                        <Border x:Name="UpdateProgressCard"
                                CornerRadius="12" Padding="20"
                                Visibility="Collapsed"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <TextBlock x:Uid="UpdateProgressLabel" x:Name="UpdateProgressLabel"
                                               Text="Скачивание обновления..."
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="UpdateProgressPct" x:Name="UpdateProgressPct"
                                               HorizontalAlignment="Right"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                </Grid>
                                <ProgressBar x:Name="UpdateProgressBar"
                                             Minimum="0" Maximum="100" Value="0"
                                             HorizontalAlignment="Stretch"/>
                                <TextBlock x:Uid="UpdateProgressDetail" x:Name="UpdateProgressDetail"
                                           Text=""
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.6"/>
                            </StackPanel>
                        </Border>

                        <!-- IPSet -->
                        <Border CornerRadius="12" Padding="24"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SpisokIpAdresovIpsetAllTxt" Text="Список IP-адресов (ipset-all.txt)"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="IpsetStatusText1" x:Name="IpsetStatusText"
                                               Text="Обновляет список заблокированных IP с GitHub"
                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                </StackPanel>
                                <Button x:Uid="UpdateIpsetButton" x:Name="UpdateIpsetButton" Grid.Column="1"
                                        Content="Обновить" VerticalAlignment="Center"
                                        Click="UpdateIpset_Click"/>
                            </Grid>
                        </Border>

                        <!-- Hosts -->
                        <Border CornerRadius="12" Padding="24"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="FaylHosts" Text="Файл hosts"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="HostsStatusText" x:Name="HostsStatusText"
                                               Text="Проверяет и обновляет системный файл hosts"
                                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                </StackPanel>
                                <Button x:Uid="UpdateHostsButton" x:Name="UpdateHostsButton" Grid.Column="1"
                                        Content="Обновить" VerticalAlignment="Center"
                                        Click="UpdateHosts_Click"/>
                            </Grid>
                        </Border>

                        <!-- Лог операций -->
                        <Border CornerRadius="12" Padding="24"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="LogOperatsiy" Text="Лог операций"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <Border Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                        CornerRadius="6" Padding="12">
                                    <ScrollViewer x:Name="UpdateLogScrollViewer" MaxHeight="200">
                                        <TextBlock x:Uid="UpdateLogText" x:Name="UpdateLogText" FontFamily="Consolas" FontSize="12"
                                                   TextWrapping="Wrap" Opacity="0.85"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ══ Тестирование ══  index=1 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE773;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="Testirovanie" Text="Тестирование" VerticalAlignment="Center"/>
                    </StackPanel>
                </PivotItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <ScrollViewer x:Name="TestScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Uid="TestOutputBox" x:Name="TestOutputBox" FontFamily="Consolas" FontSize="12"
                                     TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True"
                                     Background="Transparent" BorderThickness="0" Padding="16"/>
                        </ScrollViewer>
                    </Border>
                    <Border x:Name="InputPanel" Grid.Row="1" Visibility="Collapsed"
                            CornerRadius="12" Padding="16,12" Margin="0,8,0,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock x:Uid="InputPromptText" x:Name="InputPromptText"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="Wrap"/>
                            <ItemsControl x:Name="InputButtonsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <StackPanel x:Name="FreeInputPanel" Orientation="Horizontal"
                                        Spacing="8" Visibility="Collapsed">
                                <TextBox x:Uid="FreeInputBox" x:Name="FreeInputBox" PlaceholderText="Введите ответ..."
                                         MinWidth="200" KeyDown="FreeInputBox_KeyDown"/>
                                <Button x:Uid="Otpravit" Content="Отправить" Click="FreeInputSend_Click"
                                        Style="{ThemeResource AccentButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Button x:Uid="RunTestButton" x:Name="RunTestButton" Content="▶  Запустить тест"
                                Style="{ThemeResource AccentButtonStyle}" Click="RunTest_Click"/>
                        <Button x:Uid="StopTestButton" x:Name="StopTestButton" Content="⏹  Остановить"
                                Visibility="Collapsed" Click="StopTest_Click"/>
                        <Button x:Uid="Ochistit" Content="Очистить" Click="ClearTest_Click"/>
                        <Button x:Uid="Sokhranit" Content="💾  Сохранить" Click="SaveTest_Click"/>
                        <ProgressRing x:Name="TestProgressRing" IsActive="False"
                                      Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="TestStatusText" x:Name="TestStatusText" VerticalAlignment="Center"
                                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <!-- ══ Диагностика ══  index=2 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE9D9;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="Diagnostika" Text="Диагностика" VerticalAlignment="Center"/>
                    </StackPanel>
                </PivotItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12" Padding="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChecksList" Spacing="2"/>
                        </ScrollViewer>
                    </Border>
                    <InfoBar x:Name="SummaryBar" Grid.Row="1" Margin="0,8,0,0"
                             IsOpen="False" IsClosable="False" Title=""/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Button x:Uid="ProveritSnova" Content="🔄  Проверить снова" Click="RunDiagnostics_Click"/>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <!-- ══ Логи ══  index=3 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE7C3;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="Logi" Text="Логи" VerticalAlignment="Center"/>
                    </StackPanel>
                </PivotItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <ScrollViewer x:Name="LogsScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Uid="LogsTextBox" x:Name="LogsTextBox" FontFamily="Consolas" FontSize="12"
                                     TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True"
                                     Background="Transparent" BorderThickness="0" Padding="16"/>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <Button x:Uid="OchistitLogi" Content="Очистить логи" Click="ClearLogs_Click"/>
                        <Button x:Uid="Sokhranit1" Content="💾  Сохранить" Click="SaveLogs_Click"/>
                    </StackPanel>
                </Grid>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
