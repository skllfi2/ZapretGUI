<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ZUI.Views.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <!-- Unified icon-button style: square, subtle, consistent -->
        <Style x:Key="IconActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Pivot Grid.Row="1" x:Name="MainPivot">

            <!-- ══ Обновления ══  index=0 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE895;" FontSize="13" VerticalAlignment="Center" Opacity="0.75"/>
                        <TextBlock x:Uid="Obnovleniya" Text="Обновления" VerticalAlignment="Center"/>
                        <Border x:Name="UpdatesTabBadge"
                                Visibility="Collapsed"
                                Width="7" Height="7"
                                CornerRadius="4"
                                Background="{ThemeResource SystemFillColorAttentionBrush}"
                                VerticalAlignment="Top"
                                Margin="0,3,0,0"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10" Padding="0,10,0,28">

                        <!-- Версия zapret -->
                        <Border CornerRadius="12" Padding="20,18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3" VerticalAlignment="Center">
                                    <TextBlock x:Uid="VersiyaZapretDiscordYoutube"
                                               Text="zapret-discord-youtube"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="VersionStatusText" x:Name="VersionStatusText"
                                               Text="Проверяется..."
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.55"/>
                                </StackPanel>
                                <Button x:Uid="CheckVersionButton" x:Name="CheckVersionButton"
                                        Grid.Column="1"
                                        Content="Проверить"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        VerticalAlignment="Center"
                                        Click="CheckVersion_Click"/>
                            </Grid>
                        </Border>

                        <!-- Прогресс обновления -->
                        <Border x:Name="UpdateProgressCard"
                                CornerRadius="12" Padding="20,16"
                                Visibility="Collapsed"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <TextBlock x:Name="UpdateProgressLabel"
                                               Text="Скачивание обновления..."
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="UpdateProgressPct"
                                               HorizontalAlignment="Right"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                </Grid>
                                <ProgressBar x:Name="UpdateProgressBar"
                                             Minimum="0" Maximum="100" Value="0"
                                             HorizontalAlignment="Stretch"
                                             CornerRadius="3"/>
                                <TextBlock x:Name="UpdateProgressDetail"
                                           Text=""
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.55"/>
                            </StackPanel>
                        </Border>

                        <!-- IPSet -->
                        <Border CornerRadius="12" Padding="20,18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3" VerticalAlignment="Center">
                                    <TextBlock x:Uid="SpisokIpAdresovIpsetAllTxt"
                                               Text="ipset-all.txt"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="IpsetStatusText1" x:Name="IpsetStatusText"
                                               Text="Список заблокированных IP с GitHub"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.55"/>
                                </StackPanel>
                                <Button x:Uid="UpdateIpsetButton" x:Name="UpdateIpsetButton"
                                        Grid.Column="1"
                                        Content="Обновить"
                                        VerticalAlignment="Center"
                                        Click="UpdateIpset_Click"/>
                            </Grid>
                        </Border>

                        <!-- Hosts -->
                        <Border CornerRadius="12" Padding="20,18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="14">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3" VerticalAlignment="Center">
                                        <TextBlock x:Uid="FaylHosts" Text="Файл hosts"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock x:Uid="HostsStatusText" x:Name="HostsStatusText"
                                                   Text="Системный файл hosts"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Opacity="0.55"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Uid="HostsLastCheckText" x:Name="HostsLastCheckText"
                                                   Text=""
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Opacity="0.45"
                                                   HorizontalAlignment="Center"/>
                                        <Button x:Uid="UpdateHostsButton" x:Name="UpdateHostsButton"
                                                VerticalAlignment="Center"
                                                Click="UpdateHosts_Click">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <InfoBadge x:Name="HostsUpdateBadge"
                                                               Visibility="Collapsed"
                                                               Style="{ThemeResource AttentionIconInfoBadgeStyle}"
                                                               Width="15" Height="15"/>
                                                    <TextBlock x:Uid="ObnovitHosts" Text="Обновить hosts"/>
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Прогресс hosts -->
                                <StackPanel x:Name="HostsProgressPanel" Visibility="Collapsed" Spacing="6">
                                    <ProgressBar x:Name="HostsProgressBar"
                                                 IsIndeterminate="True"
                                                 HorizontalAlignment="Stretch"
                                                 CornerRadius="3"/>
                                    <TextBlock x:Name="HostsProgressLabel"
                                               Text="Загружается..."
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.55"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Лог операций -->
                        <Border CornerRadius="12" Padding="20,18"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="LogOperatsiy" Text="Лог операций"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <Border Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                        CornerRadius="8" Padding="14,10">
                                    <ScrollViewer x:Name="UpdateLogScrollViewer" MaxHeight="200"
                                                  VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="UpdateLogText"
                                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.8"
                                                   LineHeight="19"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ══ Тестирование ══  index=1 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE773;" FontSize="13" VerticalAlignment="Center" Opacity="0.75"/>
                        <TextBlock x:Uid="Testirovanie" Text="Тестирование" VerticalAlignment="Center"/>
                    </StackPanel>
                </PivotItem.Header>

                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ═══════════════════════════════════════════════
                         ROW 0 — Setup bar
                         ═══════════════════════════════════════════ -->
                    <Border Grid.Row="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12"
                            Padding="18,14">
                        <Grid ColumnSpacing="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- Mode -->
                                <ColumnDefinition Width="1"/>     <!-- Sep -->
                                <ColumnDefinition Width="*"/>     <!-- Strategies -->
                                <ColumnDefinition Width="Auto"/>  <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Mode selector -->
                            <StackPanel Grid.Column="0"
                                        Spacing="6"
                                        VerticalAlignment="Center"
                                        Margin="0,0,18,0">
                                <TextBlock Text="Режим"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"
                                           FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <RadioButton x:Name="ModeStandard"
                                                 Content="HTTP + Ping"
                                                 IsChecked="True"
                                                 GroupName="TestMode"
                                                 Checked="ModeChanged"/>
                                    <RadioButton x:Name="ModeDpi"
                                                 Content="DPI 16-20 KB"
                                                 GroupName="TestMode"
                                                 Checked="ModeChanged"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Vertical separator -->
                            <Rectangle Grid.Column="1"
                                       Width="1"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                       VerticalAlignment="Stretch"
                                       Margin="0,2"/>

                            <!-- Strategy selector -->
                            <StackPanel Grid.Column="2"
                                        Spacing="6"
                                        VerticalAlignment="Center"
                                        Margin="18,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Стратегии"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Opacity="0.55"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SelectedCountText"
                                               Text="0 выбрано"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Opacity="0.4"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <DropDownButton x:Name="StrategiesDropDown" MinWidth="200">
                                    <DropDownButton.Content>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE71D;" FontSize="13" VerticalAlignment="Center" Opacity="0.7"/>
                                            <TextBlock x:Name="StrategiesDropDownLabel"
                                                       Text="Выбрать стратегии"
                                                       VerticalAlignment="Center"/>
                                            <Border x:Name="StrategiesBadge"
                                                    Visibility="Collapsed"
                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    CornerRadius="10"
                                                    Padding="7,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="StrategiesBadgeText"
                                                           Text="0"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </DropDownButton.Content>

                                    <DropDownButton.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedLeft">
                                            <Flyout.FlyoutPresenterStyle>
                                                <Style TargetType="FlyoutPresenter">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="MinWidth" Value="260"/>
                                                    <Setter Property="MaxWidth" Value="320"/>
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </Flyout.FlyoutPresenterStyle>
                                            <StackPanel>
                                                <Grid Padding="14,12,10,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Стратегии"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                        <Button x:Name="SelectAllStrategiesBtn"
                                                                Content="Все"
                                                                FontSize="11" Padding="10,4"
                                                                Click="SelectAllStrategies_Click"/>
                                                        <Button x:Name="ClearAllStrategiesBtn"
                                                                Content="Сбросить"
                                                                FontSize="11" Padding="10,4"
                                                                Click="ClearAllStrategies_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                                <MenuFlyoutSeparator/>
                                                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl x:Name="ConfigChipsList" Padding="6,6,6,10"/>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">

                                <!-- ── Запустить / Стоп (взаимоисключающие) ── -->
                                <Button x:Name="RunTestButton"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="RunTest_Click"
                                        Height="36"
                                        CornerRadius="8"
                                        MinWidth="148">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <!-- E768 = Play -->
                                        <FontIcon Glyph="&#xE768;" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Запустить тест" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="StopTestButton"
                                        Visibility="Collapsed"
                                        Click="StopTest_Click"
                                        Height="36"
                                        CornerRadius="8"
                                        MinWidth="148">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <!-- E71B = Stop (filled square) -->
                                        <FontIcon Glyph="&#xE71B;" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Остановить" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- ── Разделитель ── -->
                                <Border Width="1"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        VerticalAlignment="Stretch"
                                        Margin="2,6"/>

                                <!-- ── Сохранить результаты ── -->
                                <Button x:Name="SaveTestButton"
                                        Style="{StaticResource IconActionButtonStyle}"
                                        ToolTipService.ToolTip="Сохранить результаты"
                                        Click="SaveTest_Click">
                                    <!-- E74E = Save -->
                                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                </Button>

                                <!-- ── Очистить лог ── -->
                                <Button x:Name="ClearTestButton"
                                        Style="{StaticResource IconActionButtonStyle}"
                                        ToolTipService.ToolTip="Очистить лог"
                                        Click="ClearTest_Click">
                                    <!-- E8BB = Clear / Erase -->
                                    <FontIcon Glyph="&#xE8BB;" FontSize="14"/>
                                </Button>

                                <!-- ── Разделитель ── -->
                                <Border Width="1"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        VerticalAlignment="Stretch"
                                        Margin="2,6"/>

                                <!-- ── Удалить службы (деструктивное) ── -->
                                <Button x:Name="DeleteServicesButton"
                                        Style="{StaticResource IconActionButtonStyle}"
                                        ToolTipService.ToolTip="Удалить все службы"
                                        Click="DeleteServices_Click">
                                    <!-- E74D = Delete / Trash -->
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════════════
                         ROW 1 — Progress card (shown during test)
                         ═══════════════════════════════════════════ -->
                    <Border x:Name="ProgressCard"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12"
                            Padding="18,12">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ProgressRing x:Name="TestProgressRing"
                                          Grid.Column="0"
                                          Width="20" Height="20"
                                          IsActive="False"
                                          VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock x:Name="ProgressConfigText"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           Text="Подготовка..."/>
                                <TextBlock x:Name="ProgressPhaseText"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55" Text=""/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4"
                                        HorizontalAlignment="Right">
                                <TextBlock x:Name="ProgressCountText"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.55"
                                           HorizontalAlignment="Right"/>
                                <ProgressBar x:Name="TestProgressBar"
                                             Width="130" Value="0" Maximum="100"
                                             CornerRadius="3"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════════════
                         ROW 2 — Log / Results tab content
                         ═══════════════════════════════════════════ -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Best config InfoBar -->
                        <InfoBar x:Name="BestConfigBar"
                                 Grid.Row="0"
                                 Severity="Success"
                                 IsOpen="False"
                                 IsClosable="True"
                                 CornerRadius="10"
                                 Margin="0,0,0,8">
                            <InfoBar.ActionButton>
                                <Button x:Name="ApplyBestButton"
                                        Content="Применить"
                                        Click="ApplyBest_Click"/>
                            </InfoBar.ActionButton>
                        </InfoBar>

                        <!-- Tab view -->
                        <TabView x:Name="OutputTabView"
                                 Grid.Row="1"
                                 TabWidthMode="SizeToContent"
                                 IsAddTabButtonVisible="False"
                                 TabCloseRequested="OutputTab_CloseRequested">

                            <!-- ── Лог ── -->
                            <TabViewItem x:Name="LogTab"
                                         Header="Лог"
                                         IsClosable="False">
                                <TabViewItem.IconSource>
                                    <FontIconSource Glyph="&#xE8A5;"/>
                                </TabViewItem.IconSource>
                                <ScrollViewer x:Name="LogScrollViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              Padding="0,6">
                                    <RichTextBlock x:Name="LogRichText"
                                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                                   FontSize="12.5"
                                                   LineHeight="21"
                                                   IsTextSelectionEnabled="True"
                                                   Padding="6,0"/>
                                </ScrollViewer>
                            </TabViewItem>

                            <!-- ── Результаты ── -->
                            <TabViewItem x:Name="ResultsTab"
                                         Header="Результаты"
                                         IsClosable="False"
                                         IsEnabled="False">
                                <TabViewItem.IconSource>
                                    <FontIconSource Glyph="&#xE9D9;"/>
                                </TabViewItem.IconSource>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Padding="0,6">
                                    <StackPanel x:Name="ResultsPanel" Spacing="8" Padding="0,0,0,16"/>
                                </ScrollViewer>
                            </TabViewItem>
                        </TabView>
                    </Grid>
                </Grid>
            </PivotItem>

            <!-- ══ Диагностика ══  index=2 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE9D9;" FontSize="13" VerticalAlignment="Center" Opacity="0.75"/>
                        <TextBlock x:Uid="Diagnostika" Text="Диагностика" VerticalAlignment="Center"/>
                    </StackPanel>
                </PivotItem.Header>

                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Summary bar -->
                        <RowDefinition Height="*"/>     <!-- Checks list -->
                        <RowDefinition Height="Auto"/>  <!-- Action bar  -->
                    </Grid.RowDefinitions>

                    <!-- ── Итоговый статус (показывается кодом) ── -->
                    <InfoBar x:Name="SummaryBar"
                             Grid.Row="0"
                             IsOpen="False"
                             IsClosable="False"
                             CornerRadius="10"
                             Title=""
                             Margin="0,4,0,0"/>

                    <!-- ── Список проверок ── -->
                    <Border Grid.Row="1"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Шапка карточки -->
                            <Grid Grid.Row="0" Padding="18,14,18,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="Проверки компонентов"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Name="DiagSubtitleText"
                                               Text="Выполняется проверка..."
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Opacity="0.5"/>
                                </StackPanel>
                                <!-- Счётчик результатов -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <!-- E73E = CheckMark -->
                                        <FontIcon x:Name="DiagPassIcon"
                                                  Glyph="&#xE73E;" FontSize="12"
                                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DiagPassCount"
                                                   Text="0"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <!-- E783 = Warning -->
                                        <FontIcon x:Name="DiagFailIcon"
                                                  Glyph="&#xE783;" FontSize="12"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DiagFailCount"
                                                   Text="0"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Разделитель -->
                            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                       Margin="0,0,0,0"/>

                            <!-- Сам список (заполняется из code-behind) -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ChecksList"
                                            Spacing="0"
                                            Padding="0,4,0,8"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- ── Панель действий ── -->
                    <Border Grid.Row="2"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Подсказка -->
                            <TextBlock x:Name="DiagHintText"
                                       Text="Проверяет наличие всех необходимых файлов и служб"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.5"
                                       VerticalAlignment="Center"/>

                            <!-- Кнопка -->
                            <Button Grid.Column="1"
                                    Click="RunDiagnostics_Click"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <!-- E72C = Refresh -->
                                    <FontIcon Glyph="&#xE72C;" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="Проверить снова" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ══ Логи ══  index=3 -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE7C3;" FontSize="13" VerticalAlignment="Center" Opacity="0.75"/>
                        <TextBlock x:Uid="Logi" Text="Логи" VerticalAlignment="Center"/>
                    </StackPanel>
                </PivotItem.Header>

                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>     <!-- Log card      -->
                        <RowDefinition Height="Auto"/>  <!-- Action bar    -->
                    </Grid.RowDefinitions>

                    <!-- ── Карточка с логом ── -->
                    <Border Grid.Row="0"
                            CornerRadius="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                                <RowDefinition Height="*"/>     <!-- Content -->
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Grid Grid.Row="0" Padding="16,11,12,11">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Мета-информация -->
                                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                                        <TextBlock Text="Системный журнал"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border CornerRadius="4" Padding="7,2"
                                            Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}">
                                        <TextBlock x:Name="LogsLineCountText"
                                                   Text="0 строк"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   Opacity="0.6"
                                                   FontFamily="Cascadia Mono, Consolas, monospace"/>
                                    </Border>
                                </StackPanel>

                                <!-- Кнопки тулбара -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center">

                                    <!-- Авто-скролл -->
                                    <ToggleButton x:Name="LogsAutoScrollButton"
                                                  ToolTipService.ToolTip="Авто-прокрутка"
                                                  IsChecked="True"
                                                  Width="32" Height="32"
                                                  Padding="0"
                                                  CornerRadius="6">
                                        <!-- E74B = Down arrow / scroll -->
                                        <FontIcon Glyph="&#xE74B;" FontSize="13"/>
                                    </ToggleButton>

                                    <!-- Перенос строк -->
                                    <ToggleButton x:Name="LogsWrapButton"
                                                  ToolTipService.ToolTip="Перенос строк"
                                                  IsChecked="True"
                                                  Width="32" Height="32"
                                                  Padding="0"
                                                  CornerRadius="6">
                                        <!-- E7A4 = Text wrap -->
                                        <FontIcon Glyph="&#xE7A4;" FontSize="13"/>
                                    </ToggleButton>

                                    <Border Width="1"
                                            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            VerticalAlignment="Stretch"
                                            Margin="2,4"/>

                                    <!-- Копировать всё -->
                                    <Button x:Name="LogsCopyButton"
                                            ToolTipService.ToolTip="Копировать всё"
                                            Click="CopyLogs_Click"
                                            Width="32" Height="32"
                                            Padding="0"
                                            CornerRadius="6">
                                        <!-- E8C8 = Copy -->
                                        <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                                    </Button>

                                </StackPanel>
                            </Grid>

                            <!-- Разделитель -->
                            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <!-- Лог-текст -->
                            <ScrollViewer x:Name="LogsScrollViewer"
                                          Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBox x:Uid="LogsTextBox" x:Name="LogsTextBox"
                                         FontFamily="Cascadia Mono, Consolas, monospace"
                                         FontSize="12"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="16,12"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- ── Панель действий ── -->
                    <Border Grid.Row="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="LogsLastUpdatedText"
                                       Text="Обновляется в реальном времени"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Opacity="0.45"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <Button x:Uid="OchistitLogi"
                                        Click="ClearLogs_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <!-- E74D = Delete/Clear -->
                                        <FontIcon Glyph="&#xE74D;" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Очистить" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Uid="Sokhranit1"
                                        Click="SaveLogs_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <!-- E74E = Save -->
                                        <FontIcon Glyph="&#xE74E;" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Сохранить" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
