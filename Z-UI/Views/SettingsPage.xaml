<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32,24,32,24">
        <StackPanel HorizontalAlignment="Stretch">


            <!-- ═══════════════════════════════ Запуск ═══════════════════════════════ -->
            <TextBlock x:Uid="Zapusk" Text="Запуск"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="2,0,0,6"/>
            <StackPanel Spacing="2" Margin="0,0,0,20">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="AvtozapuskVmesteSWindows" Text="Автозапуск вместе с Windows"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="ZapuskatZUIPriVkhodeVSistemu" Text="Запускать Z-UI при входе в систему"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="AutostartToggle" x:Name="AutostartToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="AutostartToggle_Toggled"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="AvtostartZapret" Text="Запускать защиту автоматически"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="ZapuskatZaschituPriOtkrytiiPrilozheniya" Text="Запускать защиту при открытии приложения"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="AutoStartZapretToggle" x:Name="AutoStartZapretToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="AutoStartZapretToggle_Toggled"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="MinimizatsiyaVTreyPriZapuske" Text="Минимизация в трей при запуске"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="SkryvatOknoPriStartePrilozheniya" Text="Скрывать окно при старте приложения"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="MinimizeToTrayToggle" x:Name="MinimizeToTrayToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="MinimizeToTrayToggle_Toggled"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="AvtoproverkaObnovleniy" Text="Автопроверка обновлений"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="ProveryatNovyeVersiiZapretPriZapuskePrilozheniya"
                                       Text="Проверять новые версии zapret при запуске приложения"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="AutoUpdateCheckToggle" x:Name="AutoUpdateCheckToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="AutoUpdateCheckToggle_Toggled"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="AvtoobnovlenieHosts" Text="Автообновление hosts"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="PrimenyatObnovleniyaHostsAvtomaticheskiPriZapuskeT"
                                       Text="Применять обновления hosts автоматически при запуске (требует прав администратора)"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="HostsAutoUpdateToggle" x:Name="HostsAutoUpdateToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="HostsAutoUpdateToggle_Toggled"/>
                    </Grid>
                </Border>

            </StackPanel>


            <!-- ═══════════════════════════════ Внешний вид ═══════════════════════════════ -->
            <TextBlock x:Uid="VneshniyVid" Text="Внешний вид"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="2,0,0,6"/>
            <StackPanel Spacing="2" Margin="0,0,0,20">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="TemaPrilozheniya" Text="Тема приложения"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="VyberiteSvetluyuTyomnuyuIliSistemnuyuTemu"
                                       Text="Выберите светлую, тёмную или системную тему"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ComboBox x:Uid="ThemeComboBox" x:Name="ThemeComboBox" Grid.Column="1"
                                  VerticalAlignment="Center" MinWidth="140"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem x:Uid="Sistemno" Content="Системно" Tag="Default"/>
                            <ComboBoxItem x:Uid="Svetlaya" Content="Светлая"  Tag="Light"/>
                            <ComboBoxItem x:Uid="Tyomnaya" Content="Тёмная"   Tag="Dark"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="YazikPrilozheniya" Text="Язык приложения"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="PerezapuskaetInterfeysDlyaSmenyYazika"
                                       Text="Перезапускает интерфейс для смены языка"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ComboBox x:Uid="LanguageComboBox" x:Name="LanguageComboBox" Grid.Column="1"
                                  VerticalAlignment="Center" MinWidth="140"
                                  SelectionChanged="LanguageComboBox_SelectionChanged">
                            <ComboBoxItem x:Uid="Russkiy"  Content="Русский"  Tag="ru"/>
                            <ComboBoxItem x:Uid="English"  Content="English"   Tag="en"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="ZvukovyeEfekty" Text="Звуковые эффекты"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="VosproizvoditZvukPriIzmeneniiStatusa"
                                       Text="Воспроизводить звук при изменении статуса"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="SoundEffectsToggle" x:Name="SoundEffectsToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="SoundEffectsToggle_Toggled"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="VsplyvayuschieUvedomleniya" Text="Всплывающие уведомления"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="PokazyvatUvedomleniyaPriIzmeneniiStatusa"
                                       Text="Показывать уведомления при изменении статуса"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <ToggleSwitch x:Uid="ToastNotificationsToggle" x:Name="ToastNotificationsToggle" Grid.Column="1"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      HorizontalAlignment="Right" MinWidth="0" Margin="0" Padding="0"
                                      Toggled="ToastNotificationsToggle_Toggled"/>
                    </Grid>
                </Border>

            </StackPanel>


            <!-- ═══════════════════════════════ Служба Windows ═══════════════════════════════ -->
            <TextBlock x:Uid="SluzhbaWindows" Text="Служба Windows"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="2,0,0,6"/>
            <StackPanel Spacing="2" Margin="0,0,0,20">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Uid="SluzhbaZapret" Text="Служба zapret"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                        <TextBlock x:Uid="ServiceStatusText" x:Name="ServiceStatusText" Text="Проверяется..."
                                   Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="UstanovitSluzhbu" Text="Установить службу"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="AvtozapuskSluzhbySWindowsBezZapuskaPrilozheniya"
                                       Text="Автозапуск службы с Windows без запуска приложения"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <Button x:Uid="InstallServiceButton" x:Name="InstallServiceButton" Grid.Column="1"
                                Content="Установить" Style="{StaticResource AccentButtonStyle}"
                                Click="InstallService_Click" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="UdalitSluzhby" Text="Удалить службы"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="UdalyaetZapretWindivertIZavershaetWinwsExe"
                                       Text="Удаляет zapret, WinDivert и завершает winws.exe"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <Button x:Uid="Udalit" Grid.Column="1" Content="Удалить"
                                Click="RemoveService_Click" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="LogOperatsiy" Text="Лог операций"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                        <Border Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                CornerRadius="4" Padding="10">
                            <ScrollViewer x:Name="ServiceLogScrollViewer" MaxHeight="120">
                                <TextBlock x:Uid="ServiceLogText" x:Name="ServiceLogText"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap" Opacity="0.85"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>


            <!-- ═══════════════════════════════ Мастер установки ═══════════════════════════════ -->
            <TextBlock x:Uid="MasterUstanovki" Text="Мастер установки"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="2,0,0,6"/>
            <StackPanel Spacing="2" Margin="0,0,0,20">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="ZapustitMasteraUstanovki" Text="Запустить мастер установки"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="PovtoritNastroyku" Text="Повторить первоначальную настройку приложения"
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <Button x:Uid="SetupWizardButton" x:Name="SetupWizardButton" Grid.Column="1"
                                Content="Открыть" Style="{StaticResource AccentButtonStyle}"
                                Click="SetupWizardButton_Click" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>


            <!-- ═══════════════════════════════ О программе ═══════════════════════════════ -->
            <TextBlock x:Uid="OProgramme" Text="О программе"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="2,0,0,6"/>
            <StackPanel Spacing="2" Margin="0,0,0,8">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Uid="ZUIopr" Text="Z-UI"
                                       Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock x:Uid="AppVersionText1" x:Name="AppVersionText" Text="Версия..."
                                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                        <HyperlinkButton x:Uid="Podrobnee" Grid.Column="1" Content="Подробнее →"
                                         VerticalAlignment="Center"
                                         Click="AboutButton_Click"/>
                    </Grid>
                </Border>

            </StackPanel>


        </StackPanel>
    </ScrollViewer>
</Page>
