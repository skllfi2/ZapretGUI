<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ZUI.Views.SetupWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Прогресс-индикатор шагов -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="560" Spacing="0">

            <!-- Шаги вверху -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Spacing="0" Margin="0,0,0,40">
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <!-- Шаг 1 -->
                    <Border x:Name="Step1Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <TextBlock x:Uid="1" Text="1" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                    <Rectangle Width="48" Height="2" VerticalAlignment="Center"
                               x:Name="Line12"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <!-- Шаг 2 -->
                    <Border x:Name="Step2Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="2">
                        <TextBlock x:Uid="2" Text="2" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Opacity="0.5"/>
                    </Border>
                    <Rectangle Width="48" Height="2" VerticalAlignment="Center"
                               x:Name="Line23"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <!-- Шаг 3 -->
                    <Border x:Name="Step3Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="2">
                        <TextBlock x:Uid="3" Text="3" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Opacity="0.5"/>
                    </Border>
                    <Rectangle Width="48" Height="2" VerticalAlignment="Center"
                               x:Name="Line34"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <!-- Шаг 4 -->
                    <Border x:Name="Step4Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="2">
                        <TextBlock x:Uid="4" Text="4" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Opacity="0.5"/>
                    </Border>
                    <Rectangle Width="48" Height="2" VerticalAlignment="Center"
                               x:Name="Line45"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    <!-- Шаг 5 -->
                    <Border x:Name="Step5Dot" Width="32" Height="32" CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="2">
                        <TextBlock x:Uid="5" Text="5" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                   Opacity="0.5"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- ══ Шаг 1: Добро пожаловать ══ -->
            <StackPanel x:Name="PanelStep1" Spacing="16" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xEA18;" FontSize="56"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <TextBlock x:Uid="DobroPozhalovatVZapretgui" Text="Добро пожаловать в ZapretGUI"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
                <TextBlock x:Uid="MasterNastroykiPomozhetUstanovitInstrumentObkhodaD" TextAlignment="Center" Opacity="0.6" TextWrapping="Wrap"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Text="Мастер настройки поможет установить инструмент обхода DPI zapret и настроить его под ваши нужды.&#x0a;&#x0a;Это займёт около 2–3 минут."/>
                <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                         Title="Требуются права администратора"
                         Message="Некоторые операции (установка службы, изменение hosts) требуют прав администратора."/>
            </StackPanel>

            <!-- ══ Шаг 2: Скачать zapret ══ -->
            <StackPanel x:Name="PanelStep2" Visibility="Collapsed" Spacing="16">
                <TextBlock x:Uid="SkachatZapret" Text="Скачать zapret"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="SkachivaemPoslednyuyuVersiyuZapretDiscordYoutubeSG" TextAlignment="Center" Opacity="0.6" TextWrapping="Wrap"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Text="Скачиваем последнюю версию zapret-discord-youtube с GitHub."/>

                <Border CornerRadius="12" Padding="24"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Uid="ZapretDiscordYoutube1" Text="zapret-discord-youtube"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Uid="WizardVersionText" x:Name="WizardVersionText"
                                           Text="Последняя версия с GitHub Releases"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.6"/>
                            </StackPanel>
                            <Button x:Uid="WizardDownloadButton" x:Name="WizardDownloadButton"
                                    Grid.Column="1"
                                    Content="Скачать"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    VerticalAlignment="Center"
                                    Click="WizardDownload_Click"/>
                        </Grid>

                        <!-- Прогресс скачивания -->
                        <StackPanel x:Name="WizardDownloadProgress" Visibility="Collapsed" Spacing="8">
                            <ProgressBar x:Name="WizardProgressBar"
                                         Minimum="0" Maximum="100" Value="0"
                                         HorizontalAlignment="Stretch"/>
                            <Grid>
                                <TextBlock x:Uid="WizardProgressText" x:Name="WizardProgressText"
                                           Text="Подготовка..."
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                                <TextBlock x:Uid="WizardProgressPct" x:Name="WizardProgressPct"
                                           HorizontalAlignment="Right"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </Grid>
                        </StackPanel>

                        <!-- Лог -->
                        <Border x:Name="WizardLogBorder" Visibility="Collapsed"
                                Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                                CornerRadius="6" Padding="12">
                            <ScrollViewer x:Name="WizardLogScroll" MaxHeight="120">
                                <TextBlock x:Uid="WizardLogText" x:Name="WizardLogText"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap" Opacity="0.8"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══ Шаг 3: Стратегия ══ -->
            <StackPanel x:Name="PanelStep3" Visibility="Collapsed" Spacing="16">
                <TextBlock x:Uid="VyborStrategii" Text="Выбор стратегии"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="StrategiyaOpredelyaetSposobObkhodaDpiRekomenduemNa" TextAlignment="Center" Opacity="0.6" TextWrapping="Wrap"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Text="Стратегия определяет способ обхода DPI. Рекомендуем начать с General."/>

                <Border CornerRadius="12" Padding="24"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Uid="Strategiya" Text="Стратегия"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Uid="VyberiteIzDostupnykhBatFaylov" Text="Выберите из доступных .bat файлов"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.6"/>
                            </StackPanel>
                            <ComboBox x:Name="WizardStrategyComboBox"
                                      Grid.Column="1" MinWidth="180"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <InfoBar x:Name="StrategyInfoBar"
                                 IsOpen="True" IsClosable="False"
                                 Severity="Informational"
                                 Title="General"
                                 Message="Универсальная стратегия для Discord, YouTube и Google. Подходит большинству пользователей."/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══ Шаг 4: Фильтры ══ -->
            <StackPanel x:Name="PanelStep4" Visibility="Collapsed" Spacing="16">
                <TextBlock x:Uid="DopolnitelnyeFiltry" Text="Дополнительные фильтры"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="NastroyteFiltryPodVashiNuzhdyMozhnoIzmenitPozzheNa" TextAlignment="Center" Opacity="0.6" TextWrapping="Wrap"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Text="Настройте фильтры под ваши нужды. Можно изменить позже на главной странице."/>

                <Border CornerRadius="12" Padding="24"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="0">

                        <Grid Padding="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Uid="GameFilter1" Text="Game Filter"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Uid="RasshiritObkhodDpiNaIgrovyePorty102465535" Text="Расширить обход DPI на игровые порты (1024–65535)"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.6" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ComboBox x:Name="WizardGameFilterComboBox"
                                      Grid.Column="1" MinWidth="160" VerticalAlignment="Center">
                                <ComboBoxItem x:Uid="Otklyuchyon1" Content="Отключён"  Tag="disabled"/>
                                <ComboBoxItem x:Uid="TcpIUdp1" Content="TCP и UDP" Tag="all"/>
                                <ComboBoxItem x:Uid="TolkoTcp1" Content="Только TCP" Tag="tcp"/>
                                <ComboBoxItem x:Uid="TolkoUdp1" Content="Только UDP" Tag="udp"/>
                            </ComboBox>
                        </Grid>

                        <Rectangle Height="1"
                                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Uid="IpsetFilter1" Text="IPSet Filter"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Uid="FiltratsiyaPoSpiskamIpAdresov" Text="Фильтрация по спискам IP-адресов"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Opacity="0.6"/>
                            </StackPanel>
                            <ComboBox x:Name="WizardIpsetFilterComboBox"
                                      Grid.Column="1" MinWidth="160" VerticalAlignment="Center">
                                <ComboBoxItem x:Uid="LyuboyIpAny1" Content="Любой IP (any)"           Tag="any"/>
                                <ComboBoxItem x:Uid="TolkoIzSpiskaLoaded1" Content="Только из списка (loaded)" Tag="loaded"/>
                                <ComboBoxItem x:Uid="NikakoyNone1" Content="Никакой (none)"            Tag="none"/>
                            </ComboBox>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══ Шаг 5: Готово ══ -->
            <StackPanel x:Name="PanelStep5" Visibility="Collapsed" Spacing="16"
                        HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE73E;" FontSize="56"
                          HorizontalAlignment="Center"
                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                <TextBlock x:Uid="VsyoGotovo" Text="Всё готово!"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="TextBlock" TextAlignment="Center" Opacity="0.6" TextWrapping="Wrap"
                           Style="{ThemeResource BodyTextBlockStyle}">
                    <Run x:Name="DoneStrategyRun" Text="Стратегия General установлена."/>
                    <LineBreak/><LineBreak/>
                    <Run Text="Нажмите «Запустить» на главной странице чтобы активировать защиту."/>
                </TextBlock>
            </StackPanel>

        </StackPanel>

        <!-- Кнопки навигации -->
        <Border Grid.Row="1"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Uid="WizardBackButton" x:Name="WizardBackButton"
                        Grid.Column="0"
                        Content="← Назад"
                        Visibility="Collapsed"
                        Click="WizardBack_Click"/>

                <TextBlock x:Uid="WizardStepLabel" x:Name="WizardStepLabel"
                           Grid.Column="1"
                           Text="Шаг 1 из 5"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button x:Uid="WizardNextButton" x:Name="WizardNextButton"
                        Grid.Column="2"
                        Content="Далее →"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="WizardNext_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
