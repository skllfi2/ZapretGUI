<Page
    x:Class="ZUI.Views.StrategiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель — список стратегий -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <ListView Grid.Row="1"
                      x:Name="StrategyListView"
                      SelectionChanged="StrategyListView_SelectionChanged"
                      CornerRadius="8">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock x:Uid="TextBlock" Text="{Binding}" Padding="8,4"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Правая панель — информация -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Uid="StrategyTitleText" Grid.Row="0"
                       x:Name="StrategyTitleText"
                       Text="Выберите стратегию"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <!-- Статус -->
                    <InfoBar x:Name="StatusInfoBar"
                             IsOpen="False"
                             IsClosable="False"/>

                    <!-- Описание -->
                    <TextBlock x:Uid="StrategyDescText" x:Name="StrategyDescText"
                               Text="Выберите стратегию из списка слева для просмотра информации."
                               TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Opacity="0.7"/>

                    <!-- Тип стратегии -->
                    <StackPanel x:Name="StrategyInfoPanel" Visibility="Collapsed" Spacing="8">
                        <TextBlock x:Uid="TipStrategii" Text="Тип стратегии:" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"/>
                        <TextBlock x:Uid="StrategyTypeText" x:Name="StrategyTypeText" Style="{ThemeResource BodyStrongTextBlockStyle}"/>

                        <TextBlock x:Uid="Primenimost" Text="Применимость:" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5" Margin="0,8,0,0"/>
                        <TextBlock x:Uid="StrategyUsageText" x:Name="StrategyUsageText" TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Кнопка -->
            <Button x:Uid="ApplyStrategyButton" Grid.Row="2"
                    x:Name="ApplyStrategyButton"
                    Content="Применить стратегию"
                    Click="ApplyStrategyButton_Click"
                    HorizontalAlignment="Stretch"
                    Margin="0,16,0,0"
                    Style="{ThemeResource AccentButtonStyle}"/>
        </Grid>
    </Grid>
</Page>