<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZUI.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="32,24">


            <!-- Версия zapret -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="VersiyaZapretDiscordYoutube" Text="Версия zapret-discord-youtube"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="VersionStatusText" x:Name="VersionStatusText"
                                   Text="Проверяется..."
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <Button x:Uid="CheckVersionButton" x:Name="CheckVersionButton" Grid.Column="1"
                            Content="Проверить"
                            Style="{ThemeResource AccentButtonStyle}"
                            VerticalAlignment="Center"
                            Click="CheckVersion_Click"/>
                </Grid>
            </Border>

            <!-- IPSet -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="SpisokIpAdresovIpsetAllTxt" Text="Список IP-адресов (ipset-all.txt)"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="IpsetStatusText1" x:Name="IpsetStatusText"
                                   Text="Обновляет список заблокированных IP с GitHub"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <Button x:Uid="UpdateIpsetButton" x:Name="UpdateIpsetButton" Grid.Column="1"
                            Content="Обновить"
                            VerticalAlignment="Center"
                            Click="UpdateIpset_Click"/>
                </Grid>
            </Border>

            <!-- Hosts -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="FaylHosts" Text="Файл hosts"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="HostsStatusText" x:Name="HostsStatusText"
                                   Text="Проверяет и обновляет системный файл hosts"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <Button x:Uid="UpdateHostsButton" x:Name="UpdateHostsButton" Grid.Column="1"
                            Content="Обновить"
                            VerticalAlignment="Center"
                            Click="UpdateHosts_Click"/>
                </Grid>
            </Border>

            <!-- Лог -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="LogOperatsiy" Text="Лог операций"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <Border Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}"
                            CornerRadius="6" Padding="12">
                        <ScrollViewer x:Name="LogScrollViewer" MaxHeight="200">
                            <TextBlock x:Uid="LogText" x:Name="LogText"
                                       FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap" Opacity="0.85"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
