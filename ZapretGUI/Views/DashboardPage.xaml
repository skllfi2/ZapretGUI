<Page
    x:Class="ZapretGUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="32,24">

            <TextBlock x:Uid="DashboardTitle" Text="Главная"
                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                       Margin="0,0,0,8"/>

            <!-- Карточка статуса -->
            <Border CornerRadius="12" Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="StatusZaschity" Text="Статус защиты"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6"/>
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusIndicator" Width="14" Height="14" Fill="Red"/>
                            <TextBlock x:Uid="StatusText" x:Name="StatusText"
                                       Text="Остановлено"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock x:Uid="StrategyText" x:Name="StrategyText"
                                   Text="Стратегия не выбрана"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Spacing="8" VerticalAlignment="Center">
                        <Button x:Uid="StartButton" x:Name="StartButton"
                                Content="▶  Запустить"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="StartButton_Click" Padding="20,10"/>
                        <Button x:Uid="StopButton" x:Name="StopButton"
                                Content="⏹  Остановить"
                                Click="StopButton_Click" Padding="20,10"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточки -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Control" Text="🎮" FontSize="28"/>
                        <TextBlock x:Uid="Discord" Text="Discord" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="ObkhodDpiAktiven" Text="Обход DPI активен"
                                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Control1" Text="▶️" FontSize="28"/>
                        <TextBlock x:Uid="Youtube" Text="YouTube" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="ObkhodDpiAktiven1" Text="Обход DPI активен"
                                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" CornerRadius="12" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Control2" Text="🔍" FontSize="28"/>
                        <TextBlock x:Uid="Google" Text="Google" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="ObkhodDpiAktiven2" Text="Обход DPI активен"
                                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Стратегия -->
            <Border CornerRadius="12" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="StrategiyaPodklyucheniya" Text="Стратегия подключения"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Uid="VyberiteOptimalnuyuStrategiyuDlyaVashegoProvaydera"
                                   Text="Выберите оптимальную стратегию для вашего провайдера"
                                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                    </StackPanel>
                    <HyperlinkButton x:Uid="Izmenit" Grid.Column="1"
                                     Content="Изменить →" VerticalAlignment="Center"
                                     Click="ChangeStrategy_Click"/>
                </Grid>
            </Border>

            <!-- InfoBar обновления -->
            <InfoBar x:Name="UpdateInfoBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Informational"
                     Title="Доступно обновление">
                <InfoBar.ActionButton>
                    <HyperlinkButton Content="Перейти к обновлениям →"
                                     Click="UpdateBanner_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>

        </StackPanel>
    </ScrollViewer>
</Page>
