<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ZapretGUI.Views.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="LogsTitle" Grid.Row="0" Text="Логи"
                   Style="{ThemeResource TitleLargeTextBlockStyle}"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1" CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <ScrollViewer x:Name="LogsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16">
                <TextBlock x:Uid="LogsTextBlock" x:Name="LogsTextBlock"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Opacity="0.9"/>
            </ScrollViewer>
        </Border>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button x:Uid="OchistitLogi" Content="Очистить логи"
                    Click="ClearLogs_Click"/>
            <Button x:Name="RunTestButton"
                    Content="▶  Тест подключения"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="RunTest_Click"/>
            <ProgressRing x:Name="TestProgressRing"
                          IsActive="False"
                          Width="20" Height="20"
                          VerticalAlignment="Center"/>
            <TextBlock x:Name="TestStatusText"
                       VerticalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Opacity="0.7"/>
        </StackPanel>
    </Grid>
</Page>
